{
  "name": "youthatlas-scrapers",
  "version": "0.1.0",
  "type": "module",
  "private": false,
  "scripts": {
    "scrape": "tsx --env-file .env src/pipeline/run.ts",
    "pipeline": "tsx --env-file .env src/pipeline/run.ts",
    "pipeline:dry": "tsx --env-file .env src/pipeline/run.ts --dry-run --limit=3",
    "pipeline:ci": "tsx src/pipeline/run.ts",
    "scrape:youthop": "tsx --env-file .env src/scrapers/run-youthop.ts",
    "scrape:ofy": "tsx --env-file .env src/scrapers/run-ofy.ts",
    "scrape:opdesk": "tsx --env-file .env src/scrapers/run-opdesk.ts",
    "scrape:afterschool": "tsx --env-file .env src/scrapers/run-afterschool.ts",
    "scrape:scholads": "tsx --env-file .env src/scrapers/run-scholads.ts",
    "process": "tsx --env-file .env src/processing/extract.ts",
    "dedup:test": "tsx --env-file .env src/processing/dedup-test.ts",
    "store": "tsx --env-file .env src/processing/store.ts",
    "store:test": "tsx --env-file .env src/processing/store-test.ts",
    "telegram:test": "tsx --env-file .env src/lib/telegram-test.ts",
    "distribute:telegram": "tsx src/distribution/telegram-post.ts",
    "distribute:email": "tsx src/distribution/email-digest.ts",
    "migrate:combined": "cat supabase/migrations/*.sql",
    "type-check": "tsc --noEmit",
    "build": "tsc"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "0.32.1",
    "@supabase/supabase-js": "2.47.12",
    "crawlee": "3.12.1",
    "fuzzball": "2.1.3",
    "playwright": "1.49.1",
    "zod": "3.24.1"
  },
  "devDependencies": {
    "@types/node": "22.10.2",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
